# Server
PORT=5000
NODE_ENV=development
# Logging: debug | info | warn | error (default: info)
LOG_LEVEL=info

# MongoDB (legacy / transition; optional when using Postgres only)
MONGODB_URI=mongodb://localhost:27017/hostel_management

# PostgreSQL (Prisma + migrations)
DATABASE_URL=postgresql://user:password@localhost:5432/hostel_db

# Auth (access token signed with per-user jwt_secret from DB; JWT_SECRET unused for access tokens)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ACCESS_EXPIRY=28800
JWT_REFRESH_EXPIRY_SECONDS=604800

# Frontend (e.g. password reset links)
FRONTEND_LINK=http://localhost:3000

# Email (e.g. Ethereal for dev)
ETHEREAL_USER=
ETHEREAL_PASSWORD=

# AWS S3 (file uploads: profile pics, mess photos)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Optional: custom public URL base (e.g. CloudFront) instead of bucket.s3.region.amazonaws.com
# AWS_S3_PUBLIC_URL_BASE=

# Redis (password reset tokens; announcement push queue)
REDIS_URL=redis://localhost:6379

# Firebase FCM (push notifications; optional)
# Path to service account JSON file, or use FIREBASE_SERVICE_ACCOUNT_JSON (stringified JSON)
FIREBASE_SERVICE_ACCOUNT_PATH=
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
